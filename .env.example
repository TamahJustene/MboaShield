# Environment variables (example)

# App
MBOASHIELD_ENV=dev
DEPLOYMENT_PROFILE=demo
TENANT_ID=cm
TENANT_DISPLAY_NAME=Cameroon
# AUTH_ENFORCE=false keeps demo APIs open; set true for government deployments
AUTH_ENFORCE=false
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=120
JWT_SECRET=change-me-in-production-mboashield
MFA_REQUIRED_ROLES=admin
# MFA_ENFORCE=true blocks privileged roles until MFA is enrolled
MFA_ENFORCE=false
TRUSTED_DEVICE_DAYS=30
TRUSTED_DEVICE_SKIP_MFA=true

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=false
PASSWORD_REQUIRE_SPECIAL=false
PASSWORD_RESET_TTL_MINUTES=30
# Return reset token in API response (demo/tests only — keep false in government)
PASSWORD_RESET_RETURN_TOKEN=false

# Database - leave empty for SQLite default under storage/
# MBOASHIELD_DB_PATH=/absolute/path/to/mboashield.db
# DATABASE_URL=postgresql+psycopg://mboashield:mboashield@localhost:5432/mboashield

# OIDC / OpenID Connect
OIDC_ENABLED=true
# OIDC_PROVIDER_ID=national-id
# OIDC_PROVIDER_NAME=National Identity Provider
# OIDC_ISSUER=https://idp.example.cm/realms/mboashield
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
# OIDC_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oidc/national-id/callback
# OIDC_TOKEN_URL=
# OIDC_JWKS_URL=
# OIDC_USERINFO_URL=
# OIDC_DEFAULT_ROLE=citizen

# SAML 2.0 SP
SAML_ENABLED=false
# SAML_SP_ENTITY_ID=https://mboashield.local/saml/metadata
# SAML_ACS_URL=http://127.0.0.1:8000/api/v1/auth/saml/acs
# SAML_IDP_ENTITY_ID=
# SAML_IDP_SSO_URL=
# SAML_IDP_X509_CERT=
# SAML_ALLOW_UNSIGNED=false
# SAML_DEFAULT_ROLE=citizen

# LDAP / Active Directory
LDAP_ENABLED=false
# LDAP_SERVER_URI=ldaps://ldap.example.cm:636
# LDAP_USE_SSL=true
# LDAP_BIND_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=cm
# LDAP_USER_SEARCH_BASE=ou=people,dc=example,dc=cm
# LDAP_GROUP_ROLE_MAP=CN=Analysts,OU=Groups,DC=example,DC=cm=analyst
# LDAP_DEFAULT_ROLE=citizen

# NTOC / Phase 7
NTOC_ENABLED=true
THREAT_LEVEL_ELEVATED=40
THREAT_LEVEL_HIGH=70
THREAT_LEVEL_CRITICAL=85
# NOTIFICATION_WEBHOOK_URL=https://example.cm/hooks/mboashield

# Threat intelligence / Phase 8 (compliant sources only — no scraping)
INTEL_ENABLED=true
# Comma-separated hosts, or * for demo
INTEL_EGRESS_ALLOWLIST=*
INTEL_INGEST_LIMIT=50

# Evidence vault / Phase 9
VAULT_ENABLED=true
VAULT_STORAGE=local
# VAULT_LOCAL_PATH=storage/vault
VAULT_MAX_BYTES=10485760
VAULT_RETENTION_DAYS=365
# VAULT_SIGNING_KEY=change-me-vault-signing
# S3 (when VAULT_STORAGE=s3)
# VAULT_S3_BUCKET=
# VAULT_S3_REGION=us-east-1
# VAULT_S3_ENDPOINT_URL=
# VAULT_S3_ACCESS_KEY=
# VAULT_S3_SECRET_KEY=

# Institution portal / Phase 10
INSTITUTION_PORTAL_ENABLED=true
