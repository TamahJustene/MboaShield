# Environment variables (example)

# App
MBOASHIELD_ENV=dev
# AUTH_ENFORCE=false keeps demo APIs open; set true for government deployments
AUTH_ENFORCE=false
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=120
JWT_SECRET=change-me-in-production-mboashield
MFA_REQUIRED_ROLES=admin

# Database - leave empty for SQLite default under storage/
# MBOASHIELD_DB_PATH=/absolute/path/to/mboashield.db
# DATABASE_URL=postgresql+psycopg://mboashield:mboashield@localhost:5432/mboashield

# OIDC / OpenID Connect readiness
# OIDC_PROVIDER_ID=national-id
# OIDC_PROVIDER_NAME=National Identity Provider
# OIDC_ISSUER=https://idp.example.cm/realms/mboashield
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
# OIDC_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oidc/national-id/callback
