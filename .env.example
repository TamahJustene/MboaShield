# Environment variables (example)

# App
MBOASHIELD_ENV=dev
# AUTH_ENFORCE=false keeps demo APIs open; set true for government deployments
AUTH_ENFORCE=false
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=120
JWT_SECRET=change-me-in-production-mboashield

# Database — leave empty for SQLite default under storage/
# MBOASHIELD_DB_PATH=/absolute/path/to/mboashield.db
# DATABASE_URL=postgresql+psycopg://mboashield:mboashield@localhost:5432/mboashield
