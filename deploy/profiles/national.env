# National deployment profile (MboaShield 2030 T5)
# Copy these values into the production secret/configuration system.
# Replace every placeholder before deployment. This file is a target profile,
# not proof of an active government deployment.
DEPLOYMENT_PROFILE=national
AUTH_ENFORCE=true
MBOASHIELD_ENV=production
MFA_ENFORCE=true
CORS_ORIGINS=https://trust.example.gov.cm
TRUSTED_HOSTS=trust.example.gov.cm
JWT_SECRET=<inject-from-kms>
WEBHOOK_SIGNING_SECRET=<inject-from-kms>
ANNOUNCEMENT_SIGNING_KEY=<inject-from-kms>
VAULT_SIGNING_KEY=<inject-from-kms>
DATABASE_URL=postgresql+psycopg://...
COUNTRY_PACK=cm
TENANT_ID=cm
INTEROP_ENABLED=true
WORKERS_ENABLED=true
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Do not set soft-auth flags in national mode.
# See docs/manuals/KMS_AND_SECRETS.md and deploy/sql/rls_tenant.sql.
